function startDaySystem() {
    setInterval(() => {
        CONFIG.dayCount++;
        bot.chat(`§6§l📅 НАСТУПИЛ ДЕНЬ ${CONFIG.dayCount} 📅`);
        
        // Проверка безумия
        checkInsanity();
        
        // Предупреждения
        sendDayWarnings();
        
    }, 20 * 60 * 1000);
}

function checkInsanity() {
    // Первая тройка - безумие на 100 день
    if (CONFIG.firstTrio.active && !CONFIG.firstTrio.defeated && !CONFIG.firstTrio.insanityTriggered && CONFIG.dayCount >= 100) {
        CONFIG.firstTrio.insanityTriggered = true;
        firstTrioInsanity();
    }
    
    // Вторая тройка - безумие на 200 день
    if (CONFIG.secondTrio.active && !CONFIG.secondTrio.defeated && !CONFIG.secondTrio.insanityTriggered && CONFIG.dayCount >= 200) {
        CONFIG.secondTrio.insanityTriggered = true;
        secondTrioInsanity();
    }
    
    // Третья тройка - безумие на 300 день
    if (CONFIG.thirdTrio.active && !CONFIG.thirdTrio.defeated && !CONFIG.thirdTrio.insanityTriggered && CONFIG.dayCount >= 300) {
        CONFIG.thirdTrio.insanityTriggered = true;
        thirdTrioInsanity();
    }
    
    // Четвёртая тройка - безумие на 400 день
    if (CONFIG.fourthTrio.active && !CONFIG.fourthTrio.defeated && !CONFIG.fourthTrio.insanityTriggered && CONFIG.dayCount >= 400) {
        CONFIG.fourthTrio.insanityTriggered = true;
        fourthTrioInsanity();
    }
    
    // Король Пустоты - безумие на 500 день
    if (CONFIG.voidKing.active && !CONFIG.voidKing.defeated && !CONFIG.voidKing.insanityTriggered && CONFIG.dayCount >= 500) {
        CONFIG.voidKing.insanityTriggered = true;
        voidKingInsanity();
    }
}

