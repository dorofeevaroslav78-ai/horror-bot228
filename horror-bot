function activateSoulWhistle() {
    const playerName = targetPlayer?.username;
    if (!playerName) return;
    
    bot.on('chat', function onSpellCast(username, message) {
        if (username === playerName && message === "СИЛОЙ ВЕЧНОСТИ, ПРИЗЫВАЮ ДУШИ ГЕРОЕВ!") {
            bot.removeListener('chat', onSpellCast);
            teleportToVoidKingdom(playerName);
        }
    });
    
    setTimeout(() => {
        bot.removeListener('chat', onSpellCast);
        bot.chat(`§4§lКОРОЛЬ ПУСТОТЫ: ВЫ НЕ ОСМЕЛИЛИСЬ! МИР ПОГИБНЕТ!`);
        badEnding();
    }, 60000);
}

