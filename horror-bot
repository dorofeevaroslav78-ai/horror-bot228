function checkAndActivateNextTrio() {
    if (CONFIG.firstTrio.defeated && !CONFIG.secondTrio.active && !CONFIG.secondTrio.defeated) {
        CONFIG.secondTrio.active = true;
        spawnSecondTrio();
        return;
    }
    
    if (CONFIG.secondTrio.defeated && !CONFIG.thirdTrio.active && !CONFIG.thirdTrio.defeated) {
        CONFIG.thirdTrio.active = true;
        spawnThirdTrio();
        return;
    }
    
    if (CONFIG.thirdTrio.defeated && !CONFIG.fourthTrio.active && !CONFIG.fourthTrio.defeated) {
        CONFIG.fourthTrio.active = true;
        spawnFourthTrio();
        return;
    }
    
    if (CONFIG.fourthTrio.defeated && !CONFIG.voidKing.active && !CONFIG.voidKing.defeated) {
        CONFIG.voidKing.active = true;
        spawnVoidKing();
        return;
    }
}

